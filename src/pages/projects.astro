---
import fs from 'fs';
import path from 'path';
import matter from 'gray-matter';
import Layout from '@/layouts/Layout.astro';
import NoFooter from "@/layouts/NoFooter.astro";
import butterfly1 from '@/assets/butterfly1.svg';
const projectsDirectory = path.resolve('./src/content/projects');
const files = fs.readdirSync(projectsDirectory);

const projects = files.map((file) => {
  const filePath = path.join(projectsDirectory, file);
  const content = fs.readFileSync(filePath, 'utf-8');
  
  const { data: { title, description, link, date, tags } } = matter(content);
  const parsedDate = new Date(date);
  return { title, description, link, date: parsedDate, tags };
});

projects.sort((a, b) => b.date.getTime() - a.date.getTime());

---
<head>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/favicon.png" />
  <link rel="manifest" href="/manifest.json" />
</head>
<NoFooter>
  <div id="project-container">
    <div id="project-wrapper">
      <h1>My Projects</h1>
      <div class="projects-list">

        {projects.map((project) => (
            <sl-card class="card-header">
              <div slot="header">
                  <a target= "_blank" href={project.link}>
                  {project.title}
                  </a>
                  <sl-animation name="flip" duration="2000" play>
                    <sl-icon-button src={butterfly1.src} href={project.link} target="_blank" label="Settings"></sl-icon-button>
                  </sl-animation>
              </div>

              {project.description}
              
              <small>{project.date.toLocaleDateString()}</small>
              <div slot="footer">
                  {project.tags.map((tag: any) => (
                      <sl-badge >{tag}</sl-badge>
                  ))}
              </div>
            </sl-card>
        ))}

      </div>
    </div>
  </div>
</NoFooter>

<style>
  h1 {
    text-align: center;
  }
  #project-container {
    display:flex;
    flex-direction: column;
    height: 100%;
    width: 100%;
  }
  #project-wrapper {
    overflow-y: auto;
    justify-content: center;
    align-items: center;
  }
  .projects-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    justify-items: center;
    justify-content: center;
    align-items: center;
    padding: 20px;
  }
  small {
    font-size: 0.9rem;
    color: #777;
  }
  .card-header {
    max-width: 300px;
    padding: 10px;
  }
  .card-header [slot='header'] {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  sl-badge::part(base)  {
    background-color: var(--sl-color-orange-400);
  }
  .card-header h3 {
    margin: 0;
  }
  .card-header sl-icon-button {
    font-size: var(--sl-font-size-medium);
  }
  @media screen and (min-width: 1536px) {
    .projects-list{
      grid-template-columns: repeat(auto-fill, minmax(500px, 1fr));
    }
    .card-header {
      font-size: 1.7rem;
      max-width: 450px;
    }
  }

  a {
      color: #ec9345;
      text-decoration: none;
  }

  a:hover {
      text-decoration: underline;
  }
</style>